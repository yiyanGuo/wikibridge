{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WikiBridge Desktop",
  "version": "0.1.0",
  "identifier": "cn.wikibridge.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "WikiBridge Desktop",
        "width": 1180,
        "height": 760,
        "minWidth": 980,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "binaries/frpc/**/*",
      "binaries/opencode/**/*",
      "binaries/llm-wiki-server/**/*",
      "../../llm_wiki/mcp-server/package.json",
      "../../llm_wiki/mcp-server/dist/**/*",
      "../../llm_wiki/mcp-server/node_modules/**/*"
    ]
  }
}
