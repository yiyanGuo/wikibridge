{
  "name": "wikibridge-desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 1420",
    "build": "tsc --noEmit && vite build",
    "ci:check": "node scripts/manual-ci.mjs",
    "test:all": "node scripts/manual-ci.mjs --include-integration",
    "test:contracts": "cargo test --manifest-path src-tauri/Cargo.toml --locked",
    "test:conda": "node scripts/check-conda-env.mjs bearfrp_test",
    "test:integration:desktop": "node scripts/run-integration.mjs",
    "test:system": "playwright test",
    "test:system:install": "playwright install chromium",
    "test:system:ui": "playwright test --ui",
    "test:system:report": "playwright show-report",
    "test:system:server": "vite --mode system-test --host 127.0.0.1 --port 1421",
    "sidecars": "node scripts/prepare-sidecars.mjs all",
    "sidecars:llm-wiki": "node scripts/prepare-sidecars.mjs llm-wiki",
    "sidecars:opencode": "node scripts/prepare-sidecars.mjs opencode",
    "sidecars:check": "node scripts/check-sidecars.mjs",
    "tauri:dev": "tauri dev",
    "tauri:build": "npm run sidecars:check && node scripts/run-tauri-build.mjs"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.9.0",
    "@tauri-apps/plugin-dialog": "^2.4.0",
    "katex": "^0.16.25",
    "lucide-react": "^0.561.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-markdown": "^10.1.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tauri-apps/cli": "^2.9.5",
    "@types/babel__generator": "^7.27.0",
    "@types/babel__template": "^7.4.4",
    "@types/babel__traverse": "^7.28.0",
    "@types/ms": "^2.1.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/unist": "^3.0.3",
    "@vitejs/plugin-react": "^5.1.2",
    "bun": "^1.3.14",
    "protoc": "^35.1.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.0"
  }
}
