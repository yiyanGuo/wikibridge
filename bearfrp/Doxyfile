# Doxygen configuration for optional BearFrps API documentation.
# Run with: doxygen Doxyfile

PROJECT_NAME           = "BearFrps"
PROJECT_BRIEF          = "frp multi-tenant management platform"
OUTPUT_DIRECTORY       = docs/doxygen
CREATE_SUBDIRS         = NO

INPUT                  = README.md \
                         docs/global_document.md \
                         docs/oral_report.md \
                         backend \
                         frontend/mock_api.js \
                         frontend/dev_serve.py \
                         demo-server/main.go \
                         demo-server/demo_server.py \
                         tools/check_comment_ratio.py
RECURSIVE              = YES
FILE_PATTERNS          = *.md \
                         *.py \
                         *.js \
                         *.go
EXCLUDE_PATTERNS       = */__pycache__/* \
                         */.pytest_cache/* \
                         */.venv/* \
                         */static/demo-server-bin/*
USE_MDFILE_AS_MAINPAGE = README.md

EXTENSION_MAPPING      = go=C

EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO
WARN_IF_UNDOCUMENTED   = NO
WARN_IF_DOC_ERROR      = YES
WARN_AS_ERROR          = NO
ALIASES                = course="\\par Course\n"

MARKDOWN_SUPPORT       = YES
JAVADOC_AUTOBRIEF      = YES
MULTILINE_CPP_IS_BRIEF = YES
OPTIMIZE_OUTPUT_JAVA   = YES

GENERATE_HTML          = YES
HTML_OUTPUT            = html
GENERATE_LATEX         = NO
GENERATE_TREEVIEW      = YES
SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES

QUIET                  = NO
