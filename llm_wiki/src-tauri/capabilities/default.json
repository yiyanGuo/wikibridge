{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-set-background-color",
    "core:window:allow-set-theme",
    "autostart:default",
    "opener:default",
    "dialog:default",
    "store:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "http://*" },
        { "url": "http://*/*" },
        { "url": "http://*:*" },
        { "url": "http://*:*/*" },
        { "url": "http://**" },
        { "url": "https://*" },
        { "url": "https://*/*" },
        { "url": "https://*:*" },
        { "url": "https://*:*/*" },
        { "url": "https://**" }
      ]
    }
  ]
}
